# ============================================================
# DevOps OS - Environment Configuration
# ============================================================

# --- LLM API Keys ---
# Using Claude 3.5 Sonnet & GPT-4o for various agents
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Optional Integrations ---
# GitHub (For PR comments, Webhooks, Repo Access)
GITHUB_TOKEN=your_github_token_here

# AWS (For Cost optimization, Infrastructure checks)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_DEFAULT_REGION=us-east-1

# PagerDuty (For incident creation/acknowledgement)
PAGERDUTY_API_KEY=your_pagerduty_key

# Slack (For notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Database ---
# For tracking audit trails and system states
DATABASE_URL=postgresql://user:pass@localhost:5432/devops_db
